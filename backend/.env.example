# LLM API 密钥（必填）
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM API 地址（根据你使用的模型服务商填写）
LLM_BASE_URL=https://api.deepseek.com

# 模型名称（根据你使用的模型填写，如 deepseek-chat、gpt-4o-mini 等）
LLM_MODEL=deepseek-chat

# HTTP 代理地址（海外 RSS 源拉取用，端口改为你代理工具的实际端口）
PROXY_URL=http://127.0.0.1:7897

# RSSHub 实例地址（本地开发用 localhost:1200，生产环境用 Docker 内部地址）
RSSHUB_BASE_URL=http://localhost:1200

# 是否自动启动本地 RSSHub 实例（设为 false 则跳过，需手动启动）
RSSHUB_AUTO_START=true

# RSSHub 项目目录（留空则默认为 backend/../rsshub）
RSSHUB_DIR=

# SQLite 数据文件路径（通常无需修改）
DATABASE_URL=sqlite:///./data/news.db
